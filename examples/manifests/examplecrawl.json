{
  "binary": {
    "name": "examplecrawl"
  },
  "branding": {
    "accent_color": "#2F81F7",
    "symbol_name": "tray"
  },
  "capabilities": [
    "status",
    "doctor",
    "refresh",
    "publish",
    "update"
  ],
  "config_options": [
    {
      "config_key": "example.token",
      "env_var": "EXAMPLECRAWL_TOKEN",
      "id": "api_token",
      "kind": "secret",
      "label": "API token"
    },
    {
      "choices": [
        "text-embedding-3-small",
        "text-embedding-3-large"
      ],
      "config_key": "embeddings.model",
      "default_value": "text-embedding-3-small",
      "env_var": "OPENAI_EMBEDDING_MODEL",
      "id": "embedding_model",
      "kind": "choice",
      "label": "Embedding model"
    }
  ],
  "config_sections": [
    {
      "id": "access",
      "option_ids": [
        "api_token"
      ],
      "title": "Example Access"
    },
    {
      "id": "ai",
      "option_ids": [
        "embedding_model"
      ],
      "title": "Embeddings"
    }
  ],
  "commands": {
    "doctor": [
      "doctor",
      "--json"
    ],
    "metadata": [
      "metadata",
      "--json"
    ],
    "publish": [
      "publish",
      "--json"
    ],
    "refresh": [
      "sync",
      "--json"
    ],
    "status": [
      "status",
      "--json"
    ],
    "update": [
      "update",
      "--json"
    ]
  },
  "description": "Example crawler metadata for CrawlBar",
  "display_name": "Example Crawl",
  "id": "examplecrawl",
  "paths": {
    "config_env": "EXAMPLECRAWL_CONFIG",
    "default_cache": "~/.examplecrawl/cache",
    "default_config": "~/.examplecrawl/config.toml",
    "default_database": "~/.examplecrawl/examplecrawl.db",
    "default_logs": "~/.examplecrawl/logs",
    "default_share": "~/.examplecrawl/share"
  },
  "privacy": {
    "contains_private_messages": false,
    "exports_secrets": false,
    "local_only_scopes": []
  },
  "schema_version": 1
}
